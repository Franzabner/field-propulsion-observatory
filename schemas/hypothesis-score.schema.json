{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.invalid/field-propulsion-observatory/hypothesis-score.schema.json",
  "title": "Hypothesis Score",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "score_id",
    "motion_claim_id",
    "synthetic",
    "known_cause_screening",
    "speculative_boundaries",
    "conclusion"
  ],
  "properties": {
    "score_id": { "type": "string", "pattern": "^score-[a-z0-9-]+$" },
    "motion_claim_id": { "type": "string", "pattern": "^claim-[a-z0-9-]+$" },
    "synthetic": { "type": "boolean", "const": true },
    "known_cause_screening": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "status", "notes"],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "aircraft",
              "drone",
              "balloon",
              "satellite",
              "bird_insect",
              "atmospheric_effect",
              "sensor_artifact",
              "electronic_warfare_spoofing",
              "classified_aerospace_platform"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["unassessed", "plausible", "screened_out", "insufficient_data"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "speculative_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "boundary"],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "plasma_sheath_flow_control",
              "electromagnetic_field_coupling",
              "magnetohydrodynamic_interaction",
              "inertia_management_hypothesis",
              "gravitational_spacetime_metric_hypothesis",
              "vacuum_energy_zero_point_hypothesis"
            ]
          },
          "boundary": { "type": "string" }
        }
      }
    },
    "conclusion": {
      "type": "string",
      "enum": ["insufficient_data", "known_cause_plausible", "bounded_unresolved", "not_reviewable"]
    }
  }
}
